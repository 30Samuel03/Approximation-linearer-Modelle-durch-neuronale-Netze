     "text": [
      "n=  500: MSE OLS = 0.252 | MSE NN = 0.592\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "n= 2000: MSE OLS = 0.254 | MSE NN = 0.342\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "n= 5000: MSE OLS = 0.235 | MSE NN = 0.270\n"
     ]
    }
   ],
   "source": [
    "from sklearn.model_selection import train_test_split\n",
    "ns = [20, 50, 100, 500, 2000, 5000]\n",
    "n_reps = 10\n",
    "mse_ols_by_n = {n_val: [] for n_val in ns}\n",
    "mse_nn_by_n  = {n_val: [] for n_val in ns}\n",
    "for n_val in ns:\n",
    "    for r in range(n_reps):\n",
    "        Xn, yn, _ = generate_data(n=n_val + 200, p=5, sigma=0.5, seed=SEED + r)\n",
    "        Xn_tr, Xn_te, yn_tr, yn_te = train_test_split(\n",
    "            Xn, yn, train_size=n_val, random_state=SEED + r\n",
    "        )\n",
    "        b_ols = fit_ols(Xn_tr, yn_tr)\n",
    "        mse_ols_by_n[n_val].append(mse(yn_te, Xn_te @ b_ols))\n",
    "        m, _ = train_ffn(Xn_tr, yn_tr, depth=2, width=64, activation='relu',\n",
    "                         optimizer='adam', lr=1e-2, epochs=1500, seed=SEED + r)\n",
    "        mse_nn_by_n[n_val].append(mse(yn_te, predict(m, Xn_te)))\n",
    "    print(f'n={n_val:>5d}: MSE OLS = {np.mean(mse_ols_by_n[n_val]):.3f} | '\n",
    "          f'MSE NN = {np.mean(mse_nn_by_n[n_val]):.3f}')\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "1418d2c4",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-07-06T14:48:22.088833Z",
     "start_time": "2026-07-06T14:48:21.973380Z"
    },
    "execution": {
     "iopub.execute_input": "2026-07-06T15:07:59.059774Z",
     "iopub.status.busy": "2026-07-06T15:07:59.059711Z",
