   "source": [
    "# F13_op_distance_over_seeds: Boxplot (Random-Init, 10 Seeds) vs. Zero-Init\n",
    "df_rand = df_e8[df_e8['init'] == 'random']\n",
    "df_zero = df_e8[df_e8['init'] == 'zero']\n",
    "\n",
    "zero_val = float(df_zero['dist_minnorm'].iloc[0])\n",
    "rand_vals = df_rand['dist_minnorm'].to_numpy()\n",
    "rand_mean = rand_vals.mean()\n",
    "rand_std  = rand_vals.std(ddof=1)\n",
    "print(f'Zero-Init: {zero_val:.4f}')\n",
    "print(f'Random-Init (n={len(rand_vals)}): Mittel={rand_mean:.4f}, Std={rand_std:.4f}')\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(6.5, 4.2))\n",
    "\n",
    "# Zero-Init: einzelner Punkt bei 0\n",
    "ax.scatter([1], [zero_val], color='#31a354', s=90, zorder=4, label=f'Zero-Init (Distanz = {zero_val:.3f})')\n",
    "\n",
    "# Random-Init: Boxplot + individuelle Punkte\n",
    "bp = ax.boxplot([rand_vals], positions=[2], widths=0.35, patch_artist=True,\n",
    "                boxprops=dict(facecolor='#fee0d2', edgecolor='#e34a33', linewidth=1.5),\n",
    "                medianprops=dict(color='#e34a33', linewidth=2),\n",
    "                whiskerprops=dict(color='#e34a33', linewidth=1.2),\n",
    "                capprops=dict(color='#e34a33', linewidth=1.2),\n",
    "                flierprops=dict(marker='o', markerfacecolor='#e34a33', markeredgecolor='#e34a33', markersize=4))\n",
    "jitter = (np.random.default_rng(0).uniform(-0.06, 0.06, size=len(rand_vals)))\n",
    "ax.scatter(np.full_like(rand_vals, 2) + jitter, rand_vals,\n",
    "           color='#e34a33', s=22, alpha=0.7, zorder=3,\n",
    "           label=f'Random-Init (n={len(rand_vals)}), Mittel={rand_mean:.3f} $\\\\pm$ {rand_std:.3f}')\n",
    "\n",
    "ax.set_xticks([1, 2])\n",
    "ax.set_xticklabels(['Zero-Init', 'Random-Init'])\n",
    "ax.set_ylabel(r'$\\|\\hat{\\beta}_{NN} - \\hat{\\beta}_{minnorm}\\|_2$')\n",
    "ax.set_title('Abstand zur Mindestnorm-Loesung: Zero-Init vs. Random-Init')\n",
    "ax.set_xlim(0.5, 2.5)\n",
    "ymax = max(zero_val, rand_vals.max())\n",
    "ax.set_ylim(-0.02, ymax * 1.25)\n",
    "ax.axhline(0, color='black', linewidth=0.7)\n",
    "ax.grid(True, axis='y', alpha=0.3)\n",
    "ax.legend(loc='upper left', fontsize=9)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(FIG_DIR, 'F13_op_distance_over_seeds.pdf'))\n",
    "plt.show()"
   ]
