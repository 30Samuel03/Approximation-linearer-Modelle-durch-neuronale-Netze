   "source": [
    "# F8: 2-Panel im 1D-Fall (tanh links, ReLU rechts) auf identischen Trainingsdaten\n",
    "x_grid = np.linspace(-5.5, 5.5, 400).reshape(-1, 1)\n",
    "y_true_grid = x_grid @ beta5\n",
    "y_ols_grid  = x_grid @ b_ols_5\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(11, 4), sharex=True, sharey=True)\n",
    "\n",
    "for ax, (act_label, m, nn_color) in zip(\n",
    "        axes,\n",
    "        [('tanh', m5_tanh, '#e34a33'),\n",
    "         ('ReLU', m5_relu, '#31a354')]):\n",
    "    y_nn_grid = predict(m, x_grid)\n",
    "    ax.scatter(X5_tr, y5_tr, alpha=0.4, s=15, color='#888', label='Trainingsdaten')\n",
    "    ax.plot(x_grid, y_true_grid, color='black', linestyle=':', label='wahre Funktion')\n",
    "    ax.plot(x_grid, y_ols_grid,  color='#2b8cbe', linewidth=2, label='OLS-Vorhersage')\n",
    "    ax.plot(x_grid, y_nn_grid,   color=nn_color, linewidth=2, label=f'NN ({act_label})')\n",
    "    ax.axvspan(-2, 2, color='#ddd', alpha=0.4, label='Trainingsbereich')\n",
    "    ax.axvspan(-5, -3, color='#fdd', alpha=0.4)\n",
    "    ax.axvspan( 3,  5, color='#fdd', alpha=0.4, label='Extrapolations-Bereich')\n",
    "    ax.set_xlabel('x')\n",
    "    ax.set_title(f'Aktivierung: {act_label}')\n",
    "    ax.legend(loc='upper left', fontsize=8)\n",
    "\n",
    "axes[0].set_ylabel('y')\n",
    "fig.suptitle('Interpolation vs. Extrapolation: gelernte Funktion im 1D-Fall')\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(FIG_DIR, 'F8_interpolation_extrapolation_funktion.pdf'))\n",
    "plt.show()"
   ]
  },
