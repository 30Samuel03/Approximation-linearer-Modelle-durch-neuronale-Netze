       "      <td>0.0215</td>\n",
       "      <td>0.6036</td>\n",
       "      <td>0.0890</td>\n",
       "    </tr>\n",
       "    <tr>\n",
       "      <th>5</th>\n",
       "      <td>X*10</td>\n",
       "      <td>OLS</td>\n",
       "      <td>0.2417</td>\n",
       "      <td>0.0086</td>\n",
       "      <td>0.2372</td>\n",
